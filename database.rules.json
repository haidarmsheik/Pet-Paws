{
  "rules": {
    "products": {
      ".read": true,
      ".write": "auth != null && auth.token.email === 'haidarmshk@gmail.com'",
      "$productId": {
        ".validate": "newData.hasChildren(['name', 'price', 'image']) && newData.child('price').isNumber() && newData.child('price').val() > 0"
      }
    },
    "orders": {
      ".read": "auth != null && auth.token.email === 'haidarmshk@gmail.com'",
      ".indexOn": ["userId", "timestamp"],
      "$orderId": {
        ".read": "auth != null && (auth.token.email === 'haidarmshk@gmail.com' || data.child('userId').val() === auth.uid)",
        ".write": "auth != null && ((!data.exists() && newData.child('userId').val() === auth.uid) || auth.token.email === 'haidarmshk@gmail.com')",
        ".validate": "newData.hasChildren(['userId', 'total', 'items', 'timestamp']) && newData.child('total').isNumber() && newData.child('total').val() > 0"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'haidarmshk@gmail.com')",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
